# Dirong Phase 0 / Phase 1 Discord recording app
# 실제 값은 이 파일에 쓰지 말고, .env 파일을 새로 만들어 복사해서 채워 주세요.

# Discord Developer Portal에서 만든 봇 토큰입니다. 절대 공유하지 마세요.
DISCORD_BOT_TOKEN=

# Discord Application ID / Client ID입니다.
DISCORD_CLIENT_ID=

# 테스트/실행할 Discord 서버(Guild) ID입니다.
DISCORD_GUILD_ID=

# Phase 0 진단 앱에서만 쓰는 고정 테스트 음성 채널 ID입니다.
# Phase 1 제품 앱은 /dirong start를 실행한 사용자의 현재 음성 채널에 들어가므로
# 이 값을 요구하지 않습니다.
DISCORD_VOICE_CHANNEL_ID=

# 결과 저장 위치입니다.
PHASE0_DATA_DIR=./data/phase0

# 음성이 끊긴 뒤 chunk를 닫기까지 기다리는 시간(ms)입니다.
PHASE0_SILENCE_MS=1000

# 너무 긴 발화가 하나의 파일로 계속 커지는 것을 막는 상한(ms)입니다.
PHASE0_MAX_CHUNK_MS=120000

# STT-safe 변환 포맷입니다. webm 또는 wav 중 하나를 사용하세요.
PHASE0_STT_SAFE_FORMAT=webm

# Discord DAVE/E2EE 대응 옵션입니다. @discordjs/voice 0.19+ 기본값도 true입니다.
PHASE0_ENABLE_DAVE=true
PHASE0_DECRYPTION_FAILURE_TOLERANCE=24

# voice debug 로그를 events.jsonl에 남깁니다.
PHASE0_DEBUG_VOICE=true

# 앱 시작 시 guild slash command를 자동 등록합니다.
PHASE0_AUTO_REGISTER_COMMANDS=true

# ---------------------------------------------------------------------------
# Phase 1 RecordingProducer MVP
# ---------------------------------------------------------------------------

# Phase 1 세션, audio chunk, STT-safe audio, SQLite DB 저장 위치입니다.
PHASE1_DATA_DIR=./data/sessions

# 비워두면 PHASE1_DATA_DIR/dirong.sqlite를 사용합니다.
PHASE1_DB_PATH=
PHASE1_DB_BUSY_TIMEOUT_MS=5000

# 음성이 끊긴 뒤 chunk를 닫기까지 기다리는 시간(ms)입니다.
PHASE1_SILENCE_MS=1000

# 이 시간을 넘으면 다음 silence에서 닫도록 표시합니다. hard cap 전까지 강제 종료하지 않습니다.
PHASE1_SOFT_ROLLOVER_MS=60000

# 너무 긴 발화가 하나의 파일로 계속 커지는 것을 막는 상한(ms)입니다.
PHASE1_MAX_CHUNK_MS=120000

# STT-safe 변환 포맷입니다. webm 또는 wav 중 하나를 사용하세요.
PHASE1_STT_SAFE_FORMAT=webm

# Phase 1은 실제 STT를 호출하지 않고 queued job만 만듭니다.
PHASE1_STT_MAX_ATTEMPTS=3
PHASE1_STT_LEASE_MS=900000

# Phase 2 Fake STT도 같은 SQLite DB와 lease 설정을 사용합니다.
# 실행 예: npm run phase2:fake-stt -- --limit 5

# ---------------------------------------------------------------------------
# Phase 3 Real STT Runner
# ---------------------------------------------------------------------------

# queued stt_jobs를 실제 STT로 처리합니다. 기본 provider는 API 비용 없는 local-whisper입니다.
# 실행 예: npm run phase3:stt -- --dry-run --limit 3
# 실제 1건 처리: npm run phase3:stt -- --provider local-whisper --limit 1
PHASE3_STT_PROVIDER=local-whisper
PHASE3_STT_LANGUAGE=ko
PHASE3_STT_TIMEOUT_MS=120000
PHASE3_LOCAL_WHISPER_COMMAND=python
PHASE3_LOCAL_WHISPER_ARGS=scripts/local-whisper-json.py
PHASE3_LOCAL_WHISPER_MODEL=small
PHASE3_LOCAL_WHISPER_DEVICE=cpu
PHASE3_LOCAL_WHISPER_COMPUTE_TYPE=int8

# Optional OpenAI STT provider입니다. 실제 값은 .env에만 넣고 로그/DB/dashboard에 노출하지 않습니다.
# 실행 예: npm run phase3:stt -- --provider openai --limit 1
OPENAI_API_KEY=
PHASE3_STT_MODEL=gpt-4o-mini-transcribe

# ---------------------------------------------------------------------------
# Phase 4 AI cleanup / meeting draft runner
# ---------------------------------------------------------------------------

# finalized session의 STT timeline을 AI 회의록 draft로 정리합니다.
# 실행 예: npm run phase4:ai-cleanup -- --session meeting_2026_05_07_120000 --dry-run
PHASE4_CLAUDE_COMMAND=claude
PHASE4_CLAUDE_MODEL=
PHASE4_AI_PREPARE_TIMEOUT_MS=5000
PHASE4_AI_LEASE_MS=
PHASE4_AI_MAX_ATTEMPTS=3
PHASE4_AI_MAX_INPUT_CHARS=120000
PHASE4_AI_TIMEOUT_MS=120000
PHASE4_AI_MAX_OUTPUT_BYTES=2097152

# 앱 실행 중 finalized session을 자동으로 AI cleanup 처리합니다.
PHASE4_AI_AUTO_CLEANUP_ENABLED=true
PHASE4_AI_AUTO_CLEANUP_POLL_MS=5000
PHASE4_AI_AUTO_CLEANUP_SESSION_BATCH_LIMIT=3
PHASE4_AI_READINESS_RETRY_MS=60000

# 이 시간보다 오래 남은 .part.ogg 파일은 startup repair item으로 표시합니다.
PHASE1_PART_REPAIR_AGE_MS=300000

# Discord DAVE/E2EE 대응 옵션입니다.
PHASE1_ENABLE_DAVE=true
PHASE1_DECRYPTION_FAILURE_TOLERANCE=24
PHASE1_DEBUG_VOICE=true

# 앱 시작 시 guild slash command /dirong을 자동 등록/갱신합니다.
PHASE1_AUTO_REGISTER_COMMANDS=true

# dashboard는 보안을 위해 127.0.0.1에만 bind합니다.
PHASE1_DASHBOARD_HOST=127.0.0.1
PHASE1_DASHBOARD_PORT=3095
PHASE1_OPEN_DASHBOARD=true

# ---------------------------------------------------------------------------
# Alone finalize
# ---------------------------------------------------------------------------

# 기본값은 안전을 위해 false입니다. true로 명시 opt-in하면
# 녹음 중인 음성 채널에 non-bot 사용자가 0명이 된 뒤 grace 시간이 지나면
# 디롱이가 /dirong stop과 같은 finalize 경로를 자동 실행합니다.
DIRONG_ALONE_FINALIZE_ENABLED=false
DIRONG_ALONE_FINALIZE_GRACE_MS=90000
